{
    "configurations": [
        {
            "name": "Launch Chrome (GCP webapp dev)",
            "request": "launch",
            "type": "chrome",
            "url": "http://localhost:5176",
            "webRoot": "${workspaceFolder}/gcp/webapp",
            "sourceMapPathOverrides": {
                "webpack:///./*": "${webRoot}/*"
            },
            "resolveSourceMapLocations": [
                "${workspaceFolder}/",
                "!/node_modules/**"
            ]
        },
        {
            "name": "Launch Chrome (GCP webapp runtime)",
            "request": "launch",
            "type": "chrome",
            "url": "http://localhost:5176",
            "webRoot": "${workspaceFolder}/gcp/webapp"
        }
    ]
}